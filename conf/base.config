/*
 * Default resource limits and retry strategy.
 * Processes declare a label (process_single / process_low / process_medium);
 * actual CPUs and memory are set here and scale with task.attempt on retry.
 */

process {

    // Retry on out-of-memory or killed signals (130-145) and Java OOM (104); fail immediately on any other error
    errorStrategy = { task.exitStatus in ((130..145) + 104) ? 'retry' : 'finish' }
    // On retry, resources scale up (x2) via task.attempt — capped at one retry per task
    maxRetries    = 1
    // No global cap on errors; each task is handled individually by errorStrategy
    maxErrors     = '-1'

    withLabel: process_single {
        cpus   = 1
        memory = { 2.GB * task.attempt }
        time   = { 2.h  * task.attempt }
    }

    withLabel: process_low {
        cpus   = { 2     * task.attempt }
        memory = { 4.GB  * task.attempt }
        time   = { 4.h   * task.attempt }
    }

    withLabel: process_medium {
        cpus   = { 6     * task.attempt }
        memory = { 36.GB * task.attempt }
        time   = { 8.h   * task.attempt }
    }

    withLabel: process_high {
        cpus   = { 12    * task.attempt }
        memory = { 72.GB * task.attempt }
        time   = { 16.h  * task.attempt }
    }

}
