/*
 * Module-level publishDir and ext.args directives.
 * publishDir = copy the output files from the temporary work/ directory to your final --outdir
 * Kept here so modules stay reusable and free of hardcoded paths.
 *
 * ext.args is passed into each process as task.ext.args.
 * Add --strict to ext.args when params.strict is true.
 
 */

process {

    withName: 'GENERATE_REFERENCE' {
        publishDir = [
            path: { "${params.outdir}" },
            mode: params.publish_dir_mode
        ]
        ext.args = { params.strict ? '--strict' : '' }
    }

    withName: 'GENERATE_CHEMICALS' {
        publishDir = [
            path: { "${params.outdir}" },
            mode: params.publish_dir_mode,
            saveAs: { fn -> fn == 'COMPOUND_MAPPING.tsv' ? null : fn }
        ]
        ext.args = { params.strict ? '--strict' : '' }
    }

    withName: 'GENERATE_ASSAY' {
        publishDir = [
            path: { "${params.outdir}" },
            mode: params.publish_dir_mode,
            saveAs: { fn -> fn == 'ASSAY_MAPPING.tsv' ? null : fn }
        ]
        ext.args = { params.strict ? '--strict' : '' }
    }

    withName: 'GENERATE_ASSAY_PARAM' {
        publishDir = [
            path: { "${params.outdir}" },
            mode: params.publish_dir_mode
        ]
        ext.args = { params.strict ? '--strict' : '' }
    }

    withName: 'GENERATE_ACTIVITY' {
        publishDir = [
            path: { "${params.outdir}" },
            mode: params.publish_dir_mode
        ]
        ext.args = { params.strict ? '--strict' : '' }
    }

}
