/*
 * Nextflow Configuration File
 * ChEMBL Submission Pipeline
 */

// ========================
// Manifest
// ========================

manifest {
    name            = 'ChEMBL-Submission-Pipeline'
    author          = 'Mahnoor Zulfiqar'
    homePage        = 'https://github.com/your-org/chembl-pipeline'
    description     = 'Pipeline to generate ChEMBL submission files from compound and activity data'
    mainScript      = 'main.nf'
    nextflowVersion = '>=21.04.0'
    version         = '1.0.0'
}

// ========================
// Default Parameters
// ========================

params {
    // Input/Output
    input_csv       = "${projectDir}/bin/smiles_list.txt"
    strain_cond     = "${projectDir}/bin/strain_cond.csv"
    outdir          = "${projectDir}/results"
    
    // Reference metadata
    ridx            = "HumanMicrobiome_DrugMetabolism"
    doi             = "10.1038/s41586-019-1291-3"
    title           = "Mapping human microbiome drug metabolism by gut bacteria and their genes"
    authors         = "Michael Zimmermann, Maria Zimmermann-Kogadeeva, Rebekka Wegmann & Andrew L. Goodman"
    abstract        = "Individuals vary widely in their responses to medicinal drugs..."
    year            = 2019
    journal_name    = "Nature"
    volume          = "570"
    issue           = "7762"
    first_page      = "462"
    last_page       = "467"
    ref_type        = "Publication"
    data_licence    = "CC0"
    
    // Process options
    max_memory      = 8.GB
    max_cpus        = 4
    max_time        = 24.h
}

// ========================
// Process Configuration
// ========================

process {
    // Default process settings
    errorStrategy = 'retry'
    maxRetries = 2
    
    // Resource allocation
    withLabel: low_memory {
        memory = 2.GB
        cpus = 1
        time = 2.h
    }
    
    withLabel: medium_memory {
        memory = 4.GB
        cpus = 2
        time = 4.h
    }
    
    withLabel: high_memory {
        memory = 8.GB
        cpus = 4
        time = 8.h
    }
    
    // Process-specific settings
    withName: GENERATE_REFERENCE {
        conda = "${projectDir}/envs/r_env.yml"
        memory = 2.GB
        cpus = 1
    }
    
    withName: GENERATE_COMPOUNDS {
        conda = "${projectDir}/envs/py_env.yml"
        memory = 4.GB
        cpus = 2
    }
    
    withName: GENERATE_ASSAY {
        conda = "${projectDir}/envs/r_env.yml"
        memory = 2.GB
        cpus = 1
    }
    
    withName: GENERATE_ACTIVITY {
        conda = "${projectDir}/envs/r_env.yml"
        memory = 4.GB
        cpus = 2
    }
    
    withName: VALIDATE_SUBMISSION {
        memory = 1.GB
        cpus = 1
    }
}

// ========================
// Executor Configuration
// ========================

executor {
    name = 'local'
    cpus = 4
    memory = '8 GB'
}

// ========================
// Conda Configuration
// ========================

conda {
    enabled = true
    useMamba = false
    createTimeout = '30 min'
}

// ========================
// Docker/Singularity Configuration
// ========================

docker {
    enabled = false
    runOptions = '-u $(id -u):$(id -g)'
}

singularity {
    enabled = false
    autoMounts = true
}

// ========================
// Reporting
// ========================

report {
    enabled = true
    file = "${params.outdir}/reports/execution_report.html"
}

timeline {
    enabled = true
    file = "${params.outdir}/reports/execution_timeline.html"
}

trace {
    enabled = true
    file = "${params.outdir}/reports/execution_trace.txt"
    fields = 'task_id,hash,native_id,process,tag,name,status,exit,module,container,cpus,time,disk,memory,attempt,submit,start,complete,duration,realtime,queue,%cpu,%mem,rss,vmem,peak_rss,peak_vmem,rchar,wchar,syscr,syscw,read_bytes,write_bytes'
}

dag {
    enabled = true
    file = "${params.outdir}/reports/pipeline_dag.html"
}

// ========================
// Profile Configuration
// ========================

profiles {
    
    standard {
        process.executor = 'local'
    }
    
    conda {
        conda.enabled = true
        process.conda = "${projectDir}/envs/r_env.yml"
    }
    
    docker {
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
        process.container = 'continuumio/miniconda3:latest'
    }
    
    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
        process.container = 'docker://continuumio/miniconda3:latest'
    }
    
    slurm {
        process.executor = 'slurm'
        process.queue = 'batch'
        process.clusterOptions = '--qos=normal'
    }
    
    debug {
        process.beforeScript = 'echo $HOSTNAME'
        cleanup = false
    }
}

// ========================
// Cleanup
// ========================

cleanup = false  // Set to true to remove work directory after successful completion
