/*
 * BioXend — nextflow.config
 * MIX-MB ChEMBL Submission Pipeline
 */

manifest {
    name            = 'BioXend'
    author          = 'Mahnoor Zulfiqar (EMBL)'
    description     = 'MIX-MB ChEMBL submission file generator'
    mainScript      = 'main.nf'
    nextflowVersion = '>=22.10.0'
    version         = '0.2.0'  // kept in sync with versions/workflow.txt by auto-version.yml
}

// ─────────────────────────────────────────────────────────────────────────────
// Default parameters (can be overridden on the command line)
// ─────────────────────────────────────────────────────────────────────────────

params {
    input            = null
    prefix           = "CIDX"
    xenobiotic_class = "xenobiotic compound"
    outdir           = "${projectDir}/results"
    strict           = false
    help             = false
    publish_dir_mode = 'copy'
}

// Keep work directory on local disk — attached volumes don't support file locks
workDir = "${System.getProperty('user.home')}/nextflow-work/bioxend"

// ─────────────────────────────────────────────────────────────────────────────
// Resource labels, retry strategy (process_single / process_low / etc.)
// ─────────────────────────────────────────────────────────────────────────────

includeConfig 'conf/base.config'

// ─────────────────────────────────────────────────────────────────────────────
// Module-level publishDir and ext.args (kept separate for reusability)
// ─────────────────────────────────────────────────────────────────────────────

includeConfig 'conf/modules.config'

// ─────────────────────────────────────────────────────────────────────────────
// Profiles
// ─────────────────────────────────────────────────────────────────────────────

profiles {

    docker {
        docker.enabled    = true
        docker.runOptions = '-u $(id -u):$(id -g)'
        process {
            container = 'zmahnoor/bioxend:latest'
        }
    }

}

// ─────────────────────────────────────────────────────────────────────────────
// Reporting (HTML reports written to outdir/reports/)
// ─────────────────────────────────────────────────────────────────────────────

def onLinux = System.properties['os.name'].toLowerCase().contains('linux')

report {
    enabled = onLinux
    file    = "${params.outdir}/reports/execution_report.html"
}

timeline {
    enabled = onLinux
    file    = "${params.outdir}/reports/execution_timeline.html"
}

trace {
    enabled = true
    file    = "${params.outdir}/reports/execution_trace.txt"
}
